# Copy to .env and edit, then: docker compose up -d

# --- HTTPS (required for installable PWA + phone push) ---
# A real domain you own -> trusted Let's Encrypt cert (needs 80/443 reachable).
# Or leave as localhost / a LAN IP -> Caddy self-signed cert (install its root CA).
ALPHA_DOMAIN=localhost

# --- Tailscale (recommended: valid HTTPS on your private tailnet, no domain) ---
# Used only by docker-compose.tailscale.yml. Make a key at:
#   https://login.tailscale.com/admin/settings/keys
# TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx

# --- Local AI briefing (served by the ollama container on your GPU) ---
# Set to off to disable AI entirely.
ALPHA_AI=ollama
ALPHA_AI_MODEL=llama3

# --- Markets ---
ALPHA_BAR=5m
ALPHA_TOP=60
ALPHA_STOCKS=on

# --- Alerts / phone push ---
ALPHA_PUSH=on
ALPHA_ALERT_IGNITION=70
ALPHA_ALERT_BUY=72

# --- External alert delivery (optional) ---
# Discord: create a channel webhook and paste its URL.
# ALPHA_DISCORD_WEBHOOK=https://discord.com/api/webhooks/xxx/yyy
# Telegram: message @BotFather to make a bot, then get your chat id.
# ALPHA_TELEGRAM_TOKEN=123456:ABC-DEF
# ALPHA_TELEGRAM_CHAT=987654321
