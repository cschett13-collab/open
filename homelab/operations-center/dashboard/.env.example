# Copy to .env and edit. .env is gitignored.

# User/group the container runs as. On UGOS, find yours with `id` over SSH.
PUID=1000
PGID=1000
TZ=America/New_York

# Host headers Homepage will accept. Add your NAS MagicDNS name + tailnet IP.
# Comma-separated, host[:port]. Example: nas:3000,100.64.0.5:3000
# (You can use "*" to allow any host, but listing them is safer.)
HOMEPAGE_ALLOWED_HOSTS=nas:3000
