# Copy to .env and edit. .env is gitignored.

# Postgres password (any strong string).
POSTGRES_PASSWORD=REPLACE_ME

# Django secret key. Generate with:  openssl rand -base64 48
PAPERLESS_SECRET_KEY=REPLACE_ME

# First-run superuser login.
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=REPLACE_ME

# How you reach Paperless on the tailnet.
PAPERLESS_URL=http://nas:8085

TZ=America/New_York
