# Copy to .env and edit. .env is gitignored.

# Where your photo/video originals are stored on the NAS.
UPLOAD_LOCATION=/volume1/photos/immich

# Where the Postgres database files live on the NAS.
DB_DATA_LOCATION=/volume1/docker/immich/pgdata

# Database credentials (any strong password).
DB_PASSWORD=REPLACE_ME
DB_USERNAME=immich
DB_DATABASE_NAME=immich

# Internal hostnames — leave as-is (they match the service names above).
DB_HOSTNAME=database
REDIS_HOSTNAME=redis

TZ=America/New_York
