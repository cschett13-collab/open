# Copy to .env and edit. .env is gitignored.

TZ=America/New_York

# Where RustDesk server keeps its key + database on the NAS.
DATA_ROOT=/volume1/docker/rustdesk

# The host clients use to reach the RELAY (hbbr). Use the NAS's MagicDNS name
# on your tailnet so relay traffic stays private. hbbs hands this address to
# clients, so it must be resolvable from them — `nas` works tailnet-wide.
RELAY_HOST=nas
