# Copy this file to backup.env and edit. backup.env is gitignored.

# NAS device name on your tailnet (MagicDNS) or its 100.x.y.z Tailscale IP.
NAS_HOST=nas

# The UGOS user you SSH in as.
NAS_USER=NAS_USER

# Where backups land on the NAS. Adjust the volume path to match UGOS.
NAS_DEST_PATH=/volume1/backups/pc

# Space-separated list of folders on the PC to back up.
# Use absolute paths. No trailing slashes needed.
SOURCES="/home/me/Documents /home/me/Pictures /home/me/Projects"

# Optional: path to a file of rsync exclude patterns (one per line).
# EXCLUDE_FILE=/home/me/.config/homelab/backup.excludes

# Set to 1 to preview without writing anything.
DRY_RUN=0
