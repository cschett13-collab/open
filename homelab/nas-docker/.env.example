# Copy to .env and edit. .env is gitignored.

# User/group the containers run as. On UGOS, find yours with `id` over SSH.
PUID=1000
PGID=1000
TZ=America/New_York

# Where container config and synced data live on the NAS.
CONFIG_ROOT=/volume1/docker/homelab/config
DATA_ROOT=/volume1/docker/homelab/data

# Only needed if you use the optional tailscale container (not the UGOS app).
# Generate a reusable auth key: admin console → Settings → Keys → Generate.
TS_AUTHKEY=tskey-auth-REPLACE_ME
